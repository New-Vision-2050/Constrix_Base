# Stage 1: Build
FROM node:22-alpine AS builder

WORKDIR /app

COPY package*.json ./
# postinstall runs copy-webviewer.js; it must exist before npm ci (Apryse assets).
COPY scripts ./scripts
RUN npm ci --legacy-peer-deps

COPY . .

# Build args - these must be set before build
ARG DEPLOYMENT_ID
ARG CACHEBUST=1
ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_API_PATH
ARG NEXT_PUBLIC_API_VERSION
ARG NEXT_PUBLIC_CACHE_BUST
ARG NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
ARG NEXT_PUBLIC_REVERB_KEY
ARG NEXT_PUBLIC_REVERB_PORT
ARG NEXT_PUBLIC_REVERB_WSS_PORT

# Set as environment variables for Next.js build
ENV DEPLOYMENT_ID=${DEPLOYMENT_ID}
ENV NEXT_PUBLIC_API_BASE_URL=${NEXT_PUBLIC_API_BASE_URL}
ENV NEXT_PUBLIC_API_PATH=${NEXT_PUBLIC_API_PATH}
ENV NEXT_PUBLIC_API_VERSION=${NEXT_PUBLIC_API_VERSION}
ENV NEXT_PUBLIC_CACHE_BUST=${NEXT_PUBLIC_CACHE_BUST}
ENV NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=${NEXT_PUBLIC_GOOGLE_MAPS_API_KEY}
ENV NEXT_PUBLIC_REVERB_KEY=${NEXT_PUBLIC_REVERB_KEY}
ENV NEXT_PUBLIC_REVERB_PORT=${NEXT_PUBLIC_REVERB_PORT}
ENV NEXT_PUBLIC_REVERB_WSS_PORT=${NEXT_PUBLIC_REVERB_WSS_PORT}

RUN echo "Cache bust: ${CACHEBUST}"
RUN echo "DEBUG [Dockerfile] NEXT_PUBLIC_GOOGLE_MAPS_API_KEY length: $(echo -n ${NEXT_PUBLIC_GOOGLE_MAPS_API_KEY} | wc -c)"
RUN echo "DEBUG [Dockerfile] NEXT_PUBLIC_GOOGLE_MAPS_API_KEY value: ${NEXT_PUBLIC_GOOGLE_MAPS_API_KEY}"
RUN echo "DEBUG [Dockerfile] NEXT_PUBLIC_API_BASE_URL: ${NEXT_PUBLIC_API_BASE_URL}"
RUN npm run build

# Stage 2: Run
FROM node:22-alpine AS runner

WORKDIR /app

# Copy built app from builder stage
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

ENV PORT=3000
EXPOSE 3000

CMD ["node", "server.js"]
